{
  "name": "costmelt",
  "version": "0.1.0",
  "description": "Official Node.js/TypeScript SDK for Cost Melt - LLM routing, caching, batching, and cost-optimization proxy",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "llm",
    "ai",
    "cost-optimization",
    "routing",
    "caching",
    "typescript"
  ],
  "author": "Cost Melt Team <support@costmelt.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/costmelt.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/costmelt/issues"
  },
  "homepage": "https://github.com/your-username/costmelt#readme",
  "dependencies": {
    "axios": "^1.6.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}

