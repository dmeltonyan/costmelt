# Cost Melt Dashboard - Environment Variables Example
# Copy this file to .env.local and fill in your values

# Backend API URL
# For Docker: use http://localhost:8000 (external access)
# For local dev: use http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Backend API key used by this app's server-side /api/* proxy routes to
# call the backend's authenticated /dashboard/* endpoints. Deliberately
# NOT prefixed with NEXT_PUBLIC_ so Next.js never inlines it into the
# browser bundle. Create one with:
#   python scripts/create_admin_key.py --user-id you@example.com
# A "read" role key is sufficient for the dashboard (see backend/security/rbac.py).
COSTMELT_DASHBOARD_API_KEY=
