								"type": "text",
								"disabled": true
							}
						],
						"url": {
							"raw": "{{base_url}}/dashboard/stats",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"dashboard",
								"stats"
							]
						},
						"description": "Get top-level summary statistics including total requests, tokens, costs, savings, and cache hit rate."
					},
					"response": []
				},
				{
					"name": "Get Usage",
					"request": {
						"method": "GET",
						"header": [
