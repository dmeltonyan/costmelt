								"disabled": true
							}
						],
						"url": {
							"raw": "{{base_url}}/dashboard/models",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"dashboard",
								"models"
							]
						},
						"description": "Get model usage and cost comparison table with requests, costs, and savings percentages."
					},
					"response": []
