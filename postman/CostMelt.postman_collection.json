{
	"info": {
		"_postman_id": "costmelt-api-collection",
		"name": "Cost Melt API",
		"description": "Complete API collection for Cost Melt - LLM routing, caching, batching, and cost-optimization proxy",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "costmelt"
	},
	"item": [
		{
			"name": "Main",
			"item": [
				{
					"name": "Route Request",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{api_key}}",
								"type": "text",
								"disabled": true
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"prompt\": \"Explain binary search algorithm with time complexity.\",\n  \"user_id\": \"demo-user-123\",\n  \"max_output_tokens\": 400\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/v1/route",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"v1",
								"route"
							]
						},
						"description": "Main endpoint for routing LLM requests through Cost Melt's optimization pipeline. Automatically handles compression, caching, routing, and batching."
					},
					"response": []
				}
			],
			"description": "Main API endpoints for LLM request routing"
		},
		{
			"name": "Dashboard",
			"item": [
				{
					"name": "Get Stats",
					"request": {
						"method": "GET",
